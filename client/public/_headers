/*
  # === QUANTUM-HARDENED SECURITY HEADERS ===
  # Tamerian Materials — Patent-Pending Technology Showcase

  # --- Transport Security ---
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  
  # --- Content Security Policy ---
  # Allows: self scripts, inline styles (Tailwind/Framer Motion), Google Fonts, CDN images, Web Audio API
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https://d2xsxph8kpxj0f.cloudfront.net https://images.unsplash.com data: blob:; media-src 'self' blob:; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; worker-src 'self' blob:; frame-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self' mailto:; upgrade-insecure-requests
  
  # --- Anti-Clickjacking ---
  X-Frame-Options: DENY
  
  # --- MIME Type Sniffing Protection ---
  X-Content-Type-Options: nosniff
  
  # --- XSS Protection (legacy browsers) ---
  X-XSS-Protection: 1; mode=block
  
  # --- Referrer Policy ---
  Referrer-Policy: strict-origin-when-cross-origin
  
  # --- Permissions Policy (restrict dangerous APIs, allow audio for Web Audio API) ---
  Permissions-Policy: accelerometer=(), ambient-light-sensor=(), autoplay=(self), battery=(), camera=(), display-capture=(), document-domain=(), encrypted-media=(self), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(self), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(self), xr-spatial-tracking=()
  
  # --- Cache Control for HTML ---
  Cache-Control: public, max-age=0, must-revalidate

# === Static Assets (JS, CSS, images) — Long-term cache ===
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# === Fonts — Long-term cache ===
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
